<!DOCTYPE html>
<html>
  <head>
    <title>SCPA Event - Sign In</title>
    <style>
      body {
        margin: 0px;
      }
      header {
        margin: 0px;
        padding: 25px;
        background-color: #a51717;
        color: rgb(238, 238, 238);
      }
      main {
        padding: 30px;
      }
      input {
        padding: 5px;
        border-radius: 8px;
        border-width: 1px;
        margin-bottom: 15px;
      }
      * {
        font-family: sans-serif;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>Please Sign In</h1>
    </header>
    <main>
      <p><b>Enter your username and password to continue.</b></p>
      <form action="/auth/login" method="post">
        <label for="username">Username</label><br>
        <input type="text" id="username" name="username" required><br>
        <label for="password">Password</label><br>
        <input type="password" id="password" name="password" required>
        <input type="submit">
      </form>
      <p style="color: #8d1616"><b><span id="dangerMessageElem"></span><span id="ssrDangerMessage">{{ dangerMessage }}</span></b></p>
      <p style="color: #56aa25"><b><span id="successMessageElem"></span><span id="ssrSuccessMessage">{{ successMessage }}</span></b></p>
      
      <script>
        const params = new URLSearchParams(window.location.search);
        if (params.get("dangerMessage")) {
          document.getElementById("dangerMessageElem").innerText = params.get("dangerMessage");
        }

        if (params.get("successMessage")) {
          document.getElementById("successMessageElem").innerText = params.get("successMessage");
        }
      </script>
    </main>
  </body>
</html>